MANUS_API_KEY=your_manus_api_key_here
MANUS_API_BASE_URL=https://api.manus.im/v1

# OAuth login gate for the /authorize page. Pick a strong password only you know.
ADMIN_PASSWORD=choose_a_strong_password_here

# Optional: set this to your Railway public URL once you have it, e.g.
# https://manus-mcp-server-production.up.railway.app
# If unset, the server infers it from the request headers (usually fine on Railway).
PUBLIC_BASE_URL=

PORT=3000
